# Hugging Face API Key (Free) - Optional, only for advanced vision features
# Get from https://huggingface.co/settings/tokens
VITE_HF_API_KEY=your_hf_token_here

# Replicate API Key (Free) - Required for image generation
# Get from https://replicate.com/
# 1. Go to https://replicate.com/
# 2. Sign up (free, no credit card required)
# 3. Copy API token from account settings
VITE_REPLICATE_API_KEY=your_replicate_token_here
