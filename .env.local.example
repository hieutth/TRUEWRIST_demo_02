# Gemini API Key (Free) - Get from https://ai.google.dev/
# 1. Go to https://ai.google.dev/
# 2. Click "Get API key in Google AI Studio"
# 3. Create a new API key for free (unlimited quota monthly)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Replicate API Key (Free) - Get from https://replicate.com/
# 1. Go to https://replicate.com/
# 2. Sign up (free, no credit card required)
# 3. Copy API token from account settings
VITE_REPLICATE_API_KEY=your_replicate_api_key_here
